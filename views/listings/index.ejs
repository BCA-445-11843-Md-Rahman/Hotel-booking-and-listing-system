<% layout("/layouts/boilerplate") %>

<style>
.all-listings-page {
    background: #f8f9fa;
    min-height: 100vh;
    padding: 40px 0;
}

.page-header {
    text-align: center;
    margin-bottom: 50px;
    animation: fadeInUp 0.8s ease-out;
}

.page-header h1 {
    font-size: 3rem;
    font-weight: 700;
    color: #667eea;
    margin-bottom: 15px;
}

.page-header p {
    font-size: 1.2rem;
    color: #4B5563;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
}

.listings-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
}

.listings-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 30px;
    animation: fadeInUp 0.8s ease-out 0.2s both;
}

.listing-card {
    background: white;
    border-radius: 20px;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    transition: all 0.3s ease;
    position: relative;
    text-decoration: none;
    color: inherit;
    display: block;
}

.listing-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
}

.listing-image-container {
    position: relative;
    width: 100%;
    height: 250px;
    overflow: hidden;
}

.listing-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
}

.listing-card:hover .listing-image {
    transform: scale(1.05);
}

.image-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, transparent 0%, rgba(0,0,0,0.1) 100%);
    opacity: 0;
    transition: opacity 0.3s ease;
}

.listing-card:hover .image-overlay {
    opacity: 1;
}

.listing-badge {
    position: absolute;
    top: 15px;
    left: 15px;
    background: #667eea;
    color: white;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 0.8rem;
    font-weight: 600;
    z-index: 2;
    box-shadow: 0 4px 12px rgba(102, 126, 234, 0.3);
}

.listing-content {
    padding: 25px;
}

.listing-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: #1F2937;
    margin-bottom: 12px;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
}

.listing-price {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 15px;
}

.price-amount {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1F2937;
}

.price-period {
    font-size: 0.9rem;
    color: #9CA3AF;
    font-weight: 400;
}

.listing-location {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #9CA3AF;
    font-size: 0.95rem;
    font-weight: 500;
}

.location-icon {
    color: #667eea;
    font-size: 1rem;
}

.listing-features {
    display: flex;
    gap: 15px;
    margin-top: 15px;
    padding-top: 15px;
    border-top: 1px solid #e9ecef;
}

.feature-tag {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 4px 10px;
    background: #F7F9FC;
    border-radius: 15px;
    font-size: 0.8rem;
    color: #4B5563;
    font-weight: 500;
}

.feature-icon {
    font-size: 0.7rem;
    color: #667eea;
}

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes fadeIn {
    from {
        opacity: 0;
    }
    to {
        opacity: 1;
    }
}

.empty-state {
    text-align: center;
    padding: 80px 20px;
    animation: fadeIn 0.8s ease-out;
}

.empty-state-icon {
    font-size: 4rem;
    color: #cbd5e1;
    margin-bottom: 20px;
}

.empty-state-title {
    font-size: 1.5rem;
    font-weight: 600;
    color: #64748b;
    margin-bottom: 10px;
}

.empty-state-text {
    font-size: 1rem;
    color: #94a3b8;
    max-width: 400px;
    margin: 0 auto;
}

@media (max-width: 768px) {
    .all-listings-page {
        padding: 20px 0;
    }
    
    .page-header h1 {
        font-size: 2rem;
    }
    
    .page-header p {
        font-size: 1rem;
    }
    
    .listings-container {
        padding: 0 15px;
    }
    
    .listings-grid {
        grid-template-columns: 1fr;
        gap: 20px;
    }
    
    .listing-content {
        padding: 20px;
    }
    
    .listing-title {
        font-size: 1.1rem;
    }
    
    .price-amount {
        font-size: 1.3rem;
    }
}

@media (min-width: 769px) and (max-width: 1024px) {
    .listings-grid {
        grid-template-columns: repeat(2, 1fr);
    }
}
</style>

<div class="all-listings-page">
    
    <!-- Flash Messages -->
    <% if(typeof success !== 'undefined' && success.length > 0) { %>
        <div class="alert alert-success alert-dismissible fade show" role="alert" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); border: none; border-radius: 12px; margin: 20px auto; max-width: 800px; padding: 16px 20px; box-shadow: 0 4px 12px rgba(16, 185, 129, 0.15);">
            <div style="display: flex; align-items: center; color: white;">
                <i class="fas fa-check-circle" style="font-size: 1.2rem; margin-right: 12px;"></i>
                <span style="font-weight: 500; font-size: 1rem;"><%= success %></span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="filter: brightness(0) invert(1); opacity: 0.8;"></button>
        </div>
    <% } %>
    
    <% if(typeof error !== 'undefined' && error.length > 0) { %>
        <div class="alert alert-danger alert-dismissible fade show" role="alert" style="background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%); border: none; border-radius: 12px; margin: 20px auto; max-width: 800px; padding: 16px 20px; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);">
            <div style="display: flex; align-items: center; color: white;">
                <i class="fas fa-exclamation-triangle" style="font-size: 1.2rem; margin-right: 12px;"></i>
                <span style="font-weight: 500; font-size: 1rem;"><%= error %></span>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close" style="filter: brightness(0) invert(1); opacity: 0.8;"></button>
        </div>
    <% } %>
    
    <!-- Page Header -->
    <div class="page-header">
        <h1>All Hotels & Villas</h1>
        <p>Discover our complete collection of premium accommodations worldwide. From luxury villas to cozy hotels, find your perfect stay.</p>
    </div>

    <!-- Listings Grid -->
    <div class="listings-container">
        <% if(allListings && allListings.length > 0) { %>
            <div class="listings-grid">
                <% for(let listing of allListings) { %>
                    <a href="/listings/<%= listing._id %>" class="listing-card">
                        <!-- Badge -->
                        <div class="listing-badge">
                            <%= listing.country || 'Premium' %>
                        </div>
                        
                        <!-- Image Container -->
                        <div class="listing-image-container">
                            <img src="<%= listing.image || 'https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80' %>" 
                                 class="listing-image" 
                                 alt="<%= listing.title %>"
                                 onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80'">
                            <div class="image-overlay"></div>
                        </div>
                        
                        <!-- Content -->
                        <div class="listing-content">
                            <h3 class="listing-title"><%= listing.title %></h3>
                            
                            <div class="listing-price">
                                <span class="price-amount">Rs <%= listing.price ? listing.price.toLocaleString("en-IN") : "N/A" %></span>
                                <span class="price-period">per night</span>
                            </div>
                            
                            <div class="listing-location">
                                <i class="fas fa-map-marker-alt location-icon"></i>
                                <span><%= listing.location %></span>
                            </div>
                            
                            <% if(listing.propertyType || listing.bedrooms || listing.maxGuests) { %>
                                <div class="listing-features">
                                    <% if(listing.propertyType) { %>
                                        <div class="feature-tag">
                                            <i class="fas fa-home feature-icon"></i>
                                            <span><%= listing.propertyType %></span>
                                        </div>
                                    <% } %>
                                    
                                    <% if(listing.bedrooms) { %>
                                        <div class="feature-tag">
                                            <i class="fas fa-bed feature-icon"></i>
                                            <span><%= listing.bedrooms %> Beds</span>
                                        </div>
                                    <% } %>
                                    
                                    <% if(listing.maxGuests) { %>
                                        <div class="feature-tag">
                                            <i class="fas fa-users feature-icon"></i>
                                            <span><%= listing.maxGuests %> Guests</span>
                                        </div>
                                    <% } %>
                                </div>
                            <% } %>
                        </div>
                    </a>
                <% } %>
            </div>
        <% } else { %>
            <!-- Empty State -->
            <div class="empty-state">
                <i class="fas fa-home empty-state-icon"></i>
                <h2 class="empty-state-title">No Properties Available</h2>
                <p class="empty-state-text">We're constantly updating our collection. Check back soon for new hotels and villas in amazing destinations!</p>
            </div>
        <% } %>
    </div>
</div>
