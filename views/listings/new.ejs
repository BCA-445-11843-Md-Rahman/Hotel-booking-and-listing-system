<% layout("/layouts/boilerplate") %>

<!-- Include Google Maps CSS -->
<link rel="stylesheet" href="/css/maps.css">

<body>
    <div class="row">
    <div class="col-8 offset-2">
        <h3>Create a New Listing</h3>
    <form method="post" action="/listings" novalidate class="needs-validation" >
        <div class="mb-3">
            <label for="title" class="form-lable">Title</label>
            <input type="text" name="listing[title]" placeholder="Add a catchy title" class="form-control" required>
            <div class="invalid-feedback">
                Please enter valid Title.
            </div>
        </div>
        <div class="mb-3">
            <label for="description" class="form-lable">Description</label>
            <textarea type="text" name="listing[description]" placeholder="Enter description" class="form-control" required></textarea>
            <div class="invalid-feedback">
                Please Enter short Description.
            </div>
        </div>
        
        <div class="mb-3">
            <label for="url" class="form-lable">Image</label>
            <input type="url" name="listing[image]" placeholder="Enter image url/link" class="form-control">
        </div>

        <div class="row">
        <div class="mb-3 col-md-4">
            <label for="price" class="form-lable">Price</label>
            <input type="number" name="listing[price]" placeholder="1200" class="form-control" >
        </div>

        <div class="mb-3 col-md-8">
            <label for="countery" class="form-lable">Country</label>
            <input type="text" name="listing[country]" placeholder="India" class="form-control" required>
            <div class="invalid-feedback">
                Country is required.
            </div>
        </div>
        </div>

        <div class="mb-3">
            <label for="location" class="form-lable">Location</label>
            <input type="text" name="listing[location]" id="location-input" placeholder="Gaya, Bihar" class="form-control" required>
            <div class="invalid-feedback">
                Location should be valid.
            </div>
        </div>

        <!-- GOOGLE MAPS LOCATION PICKER -->
        <div class="mb-4">
            <div class="map-section-header">
                <i class="fas fa-map-marked-alt"></i>
                <h5>Select Property Location on Map</h5>
            </div>
            
            <div class="map-container" style="height: 300px;">
                <div class="map-loading" id="map-loading">
                    <i class="fas fa-spinner"></i>
                    <p>Loading map...</p>
                </div>
                <div id="map"></div>
            </div>
            
            <div class="alert alert-info mt-3">
                <i class="fas fa-info-circle"></i>
                <strong>Tip:</strong> Search for a location above or click on the map to select the exact property location.
            </div>
            
            <!-- Hidden fields for coordinates -->
            <input type="hidden" name="listing[coordinates][lat]" id="lat-input" value="28.6139">
            <input type="hidden" name="listing[coordinates][lng]" id="lng-input" value="77.2090">
        </div>

        <button class="btn btn-dark add-btn">Add</button>
        <br><br>
    </form>
    </div>
    </div>

    <script>
        // Initialize map for location selection
        let mapInitialized = false;
        
        function initMapForNewListing() {
            if (mapInitialized) return;
            
            const defaultLocation = { lat: 28.6139, lng: 77.2090 };
            
            map = new google.maps.Map(document.getElementById('map'), {
                zoom: 13,
                center: defaultLocation,
                styles: [
                    {
                        "featureType": "water",
                        "elementType": "geometry",
                        "stylers": [{"color": "#e9e9e9"}, {"lightness": 17}]
                    },
                    {
                        "featureType": "landscape",
                        "elementType": "geometry",
                        "stylers": [{"color": "#f5f5f5"}, {"lightness": 20}]
                    }
                ]
            });
            
            // Add autocomplete to location input
            const autocomplete = new google.maps.places.Autocomplete(
                document.getElementById('location-input'),
                {
                    types: ['geocode'],
                    componentRestrictions: { country: 'in' }
                }
            );
            
            autocomplete.addListener('place_changed', function() {
                const place = autocomplete.getPlace();
                if (place.geometry) {
                    map.setCenter(place.geometry.location);
                    map.setZoom(15);
                    
                    // Update coordinates
                    document.getElementById('lat-input').value = place.geometry.location.lat();
                    document.getElementById('lng-input').value = place.geometry.location.lng();
                    
                    // Add marker
                    if (marker) {
                        marker.setMap(null);
                    }
                    
                    marker = new google.maps.Marker({
                        position: place.geometry.location,
                        map: map,
                        animation: google.maps.Animation.DROP
                    });
                }
            });
            
            // Add click event to map
            map.addListener('click', function(event) {
                const lat = event.latLng.lat();
                const lng = event.latLng.lng();
                
                // Update coordinates
                document.getElementById('lat-input').value = lat;
                document.getElementById('lng-input').value = lng;
                
                // Add/update marker
                if (marker) {
                    marker.setMap(null);
                }
                
                marker = new google.maps.Marker({
                    position: { lat, lng },
                    map: map,
                    animation: google.maps.Animation.DROP
                });
                
                // Get address from coordinates
                const geocoder = new google.maps.Geocoder();
                geocoder.geocode({ location: { lat, lng } }, function(results, status) {
                    if (status === 'OK' && results[0]) {
                        document.getElementById('location-input').value = results[0].formatted_address;
                    }
                });
            });
            
            // Hide loading
            document.getElementById('map-loading').style.display = 'none';
            mapInitialized = true;
        }
        
        // Override initMap for this page
        window.initMap = initMapForNewListing;
    </script>
</body>