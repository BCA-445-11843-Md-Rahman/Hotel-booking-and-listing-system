<% layout("/layouts/boilerplate") %>

<div class="row mt-4">

<div class="col-md-8 offset-md-2">

<div class="card mb-4">
    <div class="card-body">
        <h2 class="card-title"><%= listing.title %></h2>
        <img src="<%= listing.image %>" class="img-fluid rounded mb-3" alt="<%= listing.title %>" onerror="this.src='https://images.unsplash.com/photo-1566073771259-6a8506099945?ixlib=rb-4.0.3&ixid=M3wxMjA3fDB8MHxwaG90by1wYWdlfHx8fGVufDB8fHx8fA%3D%3D&auto=format&fit=crop&w=1000&q=80'">
        <p><b>Description:</b> <%= listing.description %></p>
        <p><b>Price:</b> ₹ <%= listing.price %></p>
        <p><b>Location:</b> <%= listing.location %>, <%= listing.country %></p>
    </div>
</div>

<hr>

<!-- ADMIN CONTROLS -->

<% if(currentUser && currentUser.role === "admin"){ %>

<div class="mb-3">

<a href="/listings/<%= listing._id %>/edit" class="btn btn-warning">Edit</a>

<form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display:inline">

<button class="btn btn-danger">Delete</button>

</form>

</div>

<% } %>

<hr>

<!-- BOOKING -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">🏨 Book this Villa</h4>
    </div>
    <div class="card-body">
        <% if(currentUser){ %>
            <form action="/book/<%= listing._id %>" method="POST">
                <div class="mb-3">
                    <label for="username" class="form-label">Your Name</label>
                    <input type="text" name="username" class="form-control" id="username" placeholder="Enter your name" required>
                </div>
                <div class="mb-3">
                    <label for="date" class="form-label">Booking Date</label>
                    <input type="date" name="date" class="form-control" id="date" required>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-success-custom">🏠 Book Now</button>
                </div>
            </form>
        <% } else { %>
            <div class="text-center">
                <p class="mb-3">Please login to book this villa</p>
                <a href="/login" class="btn btn-success-custom">🔐 Login to Book</a>
            </div>
        <% } %>
    </div>
</div>

<hr class="my-4">

<!-- REVIEW FORM -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">⭐ Add Review</h4>
    </div>
    <div class="card-body">
        <% if(currentUser){ %>
            <form action="/listings/<%= listing._id %>/reviews" method="POST">
                <div class="mb-3">
                    <label for="comment" class="form-label">Your Review</label>
                    <textarea name="review[comment]" class="form-control" id="comment" rows="3" placeholder="Share your experience..." required></textarea>
                </div>
                <div class="mb-3">
                    <label for="rating" class="form-label fw-bold">⭐ Rating (1-5)</label>
                    <select name="review[rating]" class="form-select form-select-lg" id="rating" required>
                        <option value="" disabled selected>⭐ Select Rating</option>
                        <option value="1">⭐ 1 - Poor</option>
                        <option value="2">⭐⭐ 2 - Fair</option>
                        <option value="3">⭐⭐⭐ 3 - Good</option>
                        <option value="4">⭐⭐⭐⭐ 4 - Very Good</option>
                        <option value="5">⭐⭐⭐⭐⭐ 5 - Excellent</option>
                    </select>
                </div>
                <div class="d-grid">
                    <button type="submit" class="btn btn-success-custom">📝 Submit Review</button>
                </div>
            </form>
        <% } else { %>
            <div class="text-center">
                <p>🔒 Please login to write a review</p>
            </div>
        <% } %>
    </div>
</div>

<hr>

<!-- REVIEWS LIST -->
<div class="card mb-4">
    <div class="card-header bg-dark text-white">
        <h4 class="mb-0">📝 All Reviews</h4>
    </div>
    <div class="card-body">
        <% if(listing.reviews.length === 0){ %>
            <div class="text-center text-muted py-3">
                <p class="mb-0">📭 No reviews yet</p>
                <small>Be the first to share your experience!</small>
            </div>
        <% } else { %>
            <% for(let review of listing.reviews){ %>
                <div class="card mb-3 border-success">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-2">
                            <h6 class="card-title mb-0 heading-green">⭐ <%= review.rating %>/5</h6>
                            <small class="text-muted">Guest Review</small>
                        </div>
                        <p class="card-text mb-2"><%= review.comment %></p>
                        <div class="d-flex justify-content-end">
                            <small class="text-muted">
                                <i class="fas fa-user-circle"></i> Verified Guest
                            </small>
                        </div>
                    </div>
                </div>
            <% } %>
        <% } %>
    </div>
</div>