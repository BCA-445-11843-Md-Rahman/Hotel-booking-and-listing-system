}

/* Empty State */
.empty-state {
    text-align: center;
    padding: 60px 20px;
    background: #F7F9FC;
    border-radius: 16px;
    margin: 40px 0;
}

.empty-state h3 {
    color: #1F2937;
    margin-bottom: 12px;
    font-weight: 600;
}

.empty-state p {
    color: #4B5563;
    margin-bottom: 24px;
}

.empty-state .btn-primary {
    background: #667eea;
    border: none;
    border-radius: 12px;
    padding: 12px 24px;
    font-weight: 500;
    transition: background 0.3s ease;
}

.empty-state .btn-primary:hover {
    background: #5a6fd8;
}

/* Responsive Design */
@media (max-width: 768px) {
    .section-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
    }
    
    .horizontal-scroll .property-card {
